# Copy this file to ".env" (same folder) and edit the values below.
# Docker Compose reads ".env" automatically, so then you only ever type:
#
#   docker compose --profile tls up -d --build
#
# ---------------------------------------------------------------------------

# Your Zebra printer's IP address. (You can also change this later in the app's
# Settings.) Find it on the printer's config label or your router's device list.
ZLG_PRINTER_HOST=10.10.100.107
ZLG_PRINTER_PORT=9100

# The address your phones and tablets will type to reach the gateway.
# Easiest choice: THIS computer's IP address on your Wi-Fi (e.g. 192.168.1.50).
# On Windows, open PowerShell and run `ipconfig` -> use the "IPv4 Address".
ZLG_HOSTNAME=192.168.1.50

# Port for plain (non-HTTPS) access on this computer, e.g. http://localhost:8080.
# Some Windows PCs reserve 8000, so 8080 is a safe default.
ZLG_HOST_PORT=8080

# ---------------------------------------------------------------------------
# Tailscale option (only if you use the `tailscale` profile instead of `tls`).
# See docs/tls-setup.md. Leave blank if you're using the Caddy option above.
# ---------------------------------------------------------------------------

# Auth key from the Tailscale admin console: Settings -> Keys -> Generate auth key.
TS_AUTHKEY=

# The device name to register in your tailnet. The app is then reachable at
# https://<ZLG_TS_HOSTNAME>.<your-tailnet>.ts.net from any device on the tailnet.
ZLG_TS_HOSTNAME=label-gateway
